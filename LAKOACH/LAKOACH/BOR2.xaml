<Page x:Class="LAKOACH.BOR2"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:LAKOACH"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="BOR2" Loaded="Page_Loaded">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="2*"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Grid.Column="1" Text="הקש.י תעודת זהות" Background="Aquamarine" FontSize="40" TextAlignment="Center" VerticalAlignment="Center" Margin="10"/>
        <TextBox Grid.Row="0" Grid.Column="1" VerticalAlignment="Bottom" Margin="10" x:Name="IdClient" FontSize="40" TextAlignment="Center"/>

        <Button Grid.Column="0" Grid.Row="0" VerticalAlignment="Center" Margin="10" FontSize="40" Background="Aquamarine" Content="אישור" Click="Button_Click"/>
        <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Bottom" Margin="10" x:Name="wellcome" FontSize="40" TextAlignment="Center"/>

        <TextBlock Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" Margin="10" Text="הקש.י קוד ספר" Background="Aquamarine" FontSize="40" TextAlignment="Center"/>
        <TextBox Grid.Row="1" Grid.Column="1" VerticalAlignment="Bottom" Margin="10" FontSize="40" TextAlignment="Center" x:Name="CodeBook" TextChanged="CodeBook_TextChanged"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Margin="10" VerticalAlignment="Center" Text="הקש.י קוד סידורי" Background="Aquamarine" FontSize="40" TextAlignment="Center"/>
        <TextBox Grid.Row="1" Grid.Column="0" Margin="10" VerticalAlignment="Bottom" FontSize="40" TextAlignment="Center" x:Name="CodeSidoory" TextChanged="CodeSidoory_TextChanged"/>

        <ScrollViewer Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="5" FlowDirection="RightToLeft">
            <Grid Background="White">
                <WrapPanel x:Name="sp1" Margin="12">
                </WrapPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
