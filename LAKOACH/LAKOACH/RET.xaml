<Page x:Class="LAKOACH.RET"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:LAKOACH"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800" Background="White"
      Title="RET">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Row="0" Grid.Column="2" FontSize="50" Text="הקש.י קוד ספר" Margin="10" FlowDirection="RightToLeft" VerticalAlignment="Top"/>
        <TextBox x:Name="CodeBook" Grid.Row="0" Grid.Column="2" Margin="10" FontSize="50" VerticalAlignment="Center" BorderThickness="3" TextAlignment="Center"/>

        <TextBlock Grid.Row="1" Grid.Column="2" FontSize="50" Text="הקש.י קוד סידורי" Margin="10" FlowDirection="RightToLeft" VerticalAlignment="Top"/>
        <TextBox x:Name="CodeSidoory" Grid.Row="1" Grid.Column="2" Margin="20" FontSize="50" VerticalAlignment="Center" BorderThickness="3" TextAlignment="Center"/>
        
        <Button x:Name="fine" Content="אישור" FontSize="40" Background="LightPink"  Margin="30" Click="fine_Click" Grid.Row="0" Grid.Column="1" Grid.RowSpan="2" Height="120"/>
        <Image x:Name="pic" Grid.Row="0" Grid.Column="0" Margin="10" Grid.RowSpan="2" Height="200" Width="200"/>
        <Button Grid.Column="2" Grid.Row="2" Content="החזר ספר" FontSize="40" Background="LightPink"  Margin="20" x:Name="returnbook" Click="returnbook_Click"/>
        <Button x:Name="more" Grid.Column="0" Grid.Row="2" Margin="10,10,10,0" FontSize="30" Background="LightPink" VerticalAlignment="Top" Content="החזרת ספר נוסף" Click="more_Click"/>
        <Button x:Name="end" Grid.Column="0" Grid.Row="2" Margin="10,0,10,10" FontSize="30" Background="LightPink" VerticalAlignment="Bottom" Content="סיום החזרת ספרים" Click="more_Click"/>
        <TextBlock Grid.Row="2" Grid.Column="1" Margin="15" TextAlignment="Center" FontSize="20" x:Name="welldone"/>
    </Grid>
</Page>
