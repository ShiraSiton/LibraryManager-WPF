<Page x:Class="LAKOACH.BOR"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:LAKOACH"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800" Background="White"
      Title="BOR">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1.1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1.1*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Row="0" Grid.Column="2" Text="הקש.י תעודת זהות" TextAlignment="Center" FontSize="40" Margin="40" VerticalAlignment="Top"/>
        <TextBox Grid.Row="0" Grid.Column="2" VerticalAlignment="Bottom" BorderThickness="3" Margin="30" Height="50" x:Name="IdClient" FontSize="30" TextAlignment="Center"/>
        <Button Grid.Row="0" Grid.Column="1" Margin="50" Content="אישור" FontSize="50"  Background="Aquamarine" x:Name="yes" Click="yes_Click"/>
        <TextBlock Grid.Row="0" Grid.Column="0" Margin="30" Background="Aquamarine" TextAlignment="Center" FontSize="35" VerticalAlignment="Center" x:Name="wellcome"/>
        <TextBlock Grid.Row="1" Grid.Column="2" Text="הקש.י קוד ספר" TextAlignment="Center" FontSize="40" Margin="40" VerticalAlignment="Top"/>
        <TextBox Grid.Row="1" Grid.Column="2" VerticalAlignment="Bottom" BorderThickness="3" Margin="30" Height="50" x:Name="CodeBook" FontSize="30" TextAlignment="Center"/>
        <TextBlock Grid.Row="2" Grid.Column="2" Text="הקש.י קוד סידורי" TextAlignment="Center" FontSize="40" Margin="40" VerticalAlignment="Top"/>
        <TextBox Grid.Row="2" Grid.Column="2" VerticalAlignment="Bottom" BorderThickness="3" Margin="30" Height="50" x:Name="CodeSidoory" FontSize="30" TextAlignment="Center"/>
        <Button Grid.Row="1" Grid.RowSpan="2" Grid.Column="1" Margin="50,100" Content="אישור" FontSize="50"  Background="Aquamarine" x:Name="ok" Click="ok_Click" />
        <Image Grid.Row="1" Grid.RowSpan="2" Grid.Column="0" Margin="40" x:Name="pic"/>
        <Button x:Name="toborrow" Grid.Column="2" Grid.Row="3" Margin="30" Background="Aquamarine" Content="השאלה" FontSize="40" Click="toborrow_Click"/>
        <TextBlock Grid.Row="3" Grid.Column="1" Margin="30" Background="Aquamarine" TextAlignment="Center" FontSize="35" VerticalAlignment="Center" x:Name="welldone"/>
        <Button Grid.Column="0" Grid.Row="3" VerticalAlignment="Top" Margin="20" Content="השאלת ספר נוסף"  Background="Aquamarine" FontSize="30" x:Name="more" Click="more_Click"/>
        <Button Grid.Column="0" Grid.Row="3" VerticalAlignment="Bottom" Margin="20" Content="סיום"  Background="Aquamarine" FontSize="30" x:Name="end" Click="end_Click"/>
    </Grid>
</Page>
