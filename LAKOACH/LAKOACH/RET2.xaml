<Page x:Class="LAKOACH.RET2"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:LAKOACH"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="RET2">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="3*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        <TextBlock Background="Lavender" Grid.Column="1" Grid.Row="0" Margin="15" Text="הקש.י תעודת זהות" TextAlignment="Center" FontSize="40" VerticalAlignment="Bottom"/>
        <TextBox x:Name="IdClient" Grid.Row="1" Grid.Column="1" Margin="25" TextAlignment="Center" FontSize="40" BorderThickness="3"/>

        <Button Grid.Column="0" Grid.Row="0" Content="אישור" Margin="15" FontSize="40" Background="Lavender" x:Name="ok" VerticalAlignment="Bottom" Click="ok_Click"/>
        <TextBlock Grid.Row="1" Grid.Column="0" Margin="25" FontSize="40" TextAlignment="Center" x:Name="wellcome"/>

        <ScrollViewer Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="30" FlowDirection="RightToLeft">
            <Grid Background="White">
                <WrapPanel x:Name="sp1" Margin="12">
                </WrapPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
