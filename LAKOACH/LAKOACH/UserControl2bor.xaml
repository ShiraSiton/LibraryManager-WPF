<UserControl x:Class="LAKOACH.UserControl2bor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LAKOACH"
             mc:Ignorable="d" 
            d:DesignHeight="600" d:DesignWidth="450" Margin="6" Background="White" MouseDoubleClick="UserControl_MouseDoubleClick">
    <Grid  FlowDirection="LeftToRight">
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="4*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>
        <Border BorderBrush="DarkGray" BorderThickness="8" Grid.RowSpan="5" CornerRadius="20" Background="#FFF8F9F2"/>
        <TextBlock Text="{Binding NameBook}" Grid.Row="0" Margin="20" FontSize="50" x:Name="NameBook" FontFamily="Fb Poza" FlowDirection="RightToLeft"/>
        <TextBlock Text="{Binding CodeBook}" Grid.Row="2" Margin="20" HorizontalAlignment="Left" Width="200" FontSize="50" x:Name="CodeBook" FontFamily="Fb Poza"/>
        <TextBlock Text="{Binding CodeSidoory}" Grid.Row="3" Margin="20" HorizontalAlignment="Left" Width="200" FontSize="50" x:Name="CodeSidoory" FontFamily="Fb Poza"/>
        <TextBlock Grid.Row="2" Text=":קוד ספר" HorizontalAlignment="Right" FontSize="50" FontFamily="Fb Poza" Margin="20"/>
        <TextBlock Grid.Row="3" Text=":קוד סידורי" HorizontalAlignment="Right" FontSize="50" FontFamily="Fb Poza" Margin="20"/>
        <Image Grid.Row="1" x:Name="pic" Height="200" Width="150"/>
        <Button Grid.Row="4" Height="50" Width="150" Content="להשאלה" FontSize="40" FontFamily="Fb Poza" Background="Aquamarine" x:Name="toborrow" Margin="10" Click="toborrow_Click"/>
    </Grid>
</UserControl>

