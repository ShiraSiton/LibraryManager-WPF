<Window x:Class="LAKOACH.MainWindow" 
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LAKOACH"
        mc:Ignorable="d" 
        Title="MainWindow" Height="450" Width="800"> 
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition  Height="auto"/>
            <RowDefinition />
        </Grid.RowDefinitions>
        <Menu Grid.Row="0" FlowDirection="RightToLeft">
            <MenuItem Header="ספרים" FontSize="50" Background="BlanchedAlmond" Margin="10,0"  x:Name="us1" Click="us1_Click"/>
            <MenuItem Header="השאלות" FontSize="50" Background="Aquamarine" Margin="10,0" x:Name="bor" Click="bor_Click" />
            <MenuItem Header="החזרות לפי תעודת זהות" Background="Lavender" FontSize="45" Margin="10,0" x:Name="ret2" Click="ret2_Click"/>
            <MenuItem Header="החזרות לפי קוד ספר" FontSize="45" Background="LightPink" Margin="10,0" x:Name="ret" Click="ret_Click" />
        </Menu>
        <Frame x:Name="myframe" Grid.Row="1"/>
    </Grid>
</Window>
