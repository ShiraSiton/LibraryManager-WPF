<Page x:Class="SAFRANIT.S1"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SAFRANIT"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="S1" Background="White" Loaded="Page_Loaded">

    <Page.Resources>

        <!--The tool tip for the TextBox to display the validation error message.-->
        <Style x:Key="textBoxInError" TargetType="TextBox">
            <Style.Triggers>
                <Trigger Property="Validation.HasError" Value="true">
                    <Setter Property="ToolTip"
                            Value="{Binding RelativeSource={x:Static RelativeSource.Self},
                        Path=(Validation.Errors)[0].ErrorContent}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="2*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="4*"/>
            <ColumnDefinition Width="4*"/>
            <ColumnDefinition Width="4*"/>
            <ColumnDefinition Width="4*"/>
            <ColumnDefinition Width="4*"/>
            <ColumnDefinition Width="5*"/>
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Row="0" Grid.Column="0" Text="מספר ילדים"  FontSize="30" VerticalAlignment="Bottom" HorizontalAlignment="Right"/>
        <TextBlock Grid.Row="0" Grid.Column="1" Text="טלפון"  FontSize="30" VerticalAlignment="Bottom" HorizontalAlignment="Right"/>
        <TextBlock Grid.Row="0" Grid.Column="2" Text="תעודת זהות"  FontSize="30" VerticalAlignment="Bottom" HorizontalAlignment="Right"/>
        <TextBlock Grid.Row="0" Grid.Column="3" Text="שם משפחה"  FontSize="30" VerticalAlignment="Bottom"  HorizontalAlignment="Right"/>
        <TextBlock Grid.Row="0" Grid.Column="4" Text="שם פרטי"  FontSize="30" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="5"/>
        <TextBox Grid.Row="1" Grid.Column="0" Margin="10" FontSize="20" x:Name="Children">
            <Binding Path="Str1" Mode="OneWayToSource">
                <Binding.ValidationRules>
                    <local:IsNumber/>
                </Binding.ValidationRules>
            </Binding>
        </TextBox>
        <TextBox Grid.Row="1" Grid.Column="1" Margin="10" FontSize="20" x:Name="Fone">
            <Binding Path="Str1" Mode="OneWayToSource">
                <Binding.ValidationRules>
                    <local:IsCellPhone/>
                </Binding.ValidationRules>
            </Binding>
        </TextBox>
        <TextBox Grid.Row="1" Grid.Column="2" Margin="10" FontSize="20" x:Name="IdClient">
            <Binding Path="Str1" Mode="OneWayToSource">
                <Binding.ValidationRules>
                    <local:IsId/>
                </Binding.ValidationRules>
            </Binding>
        </TextBox>
        <TextBox Grid.Row="1" Grid.Column="3" Margin="10" FontSize="20" x:Name="Lname" >
            <Binding Path="Str1" Mode="OneWayToSource">
                <Binding.ValidationRules>
                    <local:isHebrewRule2/>
                </Binding.ValidationRules>
            </Binding>
        </TextBox>
        <TextBox Grid.Row="1" Grid.Column="4" Margin="10" FontSize="20" x:Name="Fname">
            <Binding Path="Str1" Mode="OneWayToSource">
                <Binding.ValidationRules>
                    <local:isHebrewRule2/>
                </Binding.ValidationRules>
            </Binding>
        </TextBox>
        <ListView x:Name="lstvclients" Grid.Column="0" Grid.Row="2" Grid.ColumnSpan="5"  SelectionChanged="lstvclients_SelectionChanged" Margin="10">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="מספר ילדים" Width="200" DisplayMemberBinding="{Binding Children}"/>
                    <GridViewColumn Header="טלפון" Width="200" DisplayMemberBinding="{Binding Fone}"/>
                    <GridViewColumn Header="תעודת זהות" Width="200" DisplayMemberBinding="{Binding IdClient}"/>
                    <GridViewColumn Header="שם משפחה" Width="200" DisplayMemberBinding="{Binding Fname}"/>
                    <GridViewColumn Header="שם פרטי" Width="200" DisplayMemberBinding="{Binding Lname}"/>
                </GridView>
            </ListView.View>
        </ListView>
        <Button Grid.Column="5" Grid.Row="0"  Background="Aquamarine" Content="New" FontSize="40" Height="70" x:Name="newclients" Click="newclients_Click" />
        <Button Grid.Column="5" Grid.Row="1" Background="Aquamarine" Content="Add" FontSize="40" Height="70" x:Name="addclients" Click="addclients_Click"/>
        <Button Grid.Column="5" Grid.Row="2"  Background="Aquamarine" Content="Update" FontSize="40" Height="70" VerticalAlignment="Top" x:Name="upclients" Click="upclients_Click" />

        <Button Grid.Column="5" Grid.Row="3" VerticalAlignment="Top" Background="Aquamarine" Content="New" FontSize="45" x:Name="newsignup" Click="newsignup_Click" />
        <Button Grid.Column="5" Grid.Row="3" VerticalAlignment="Bottom" Background="Aquamarine" Content="Add" FontSize="45" x:Name="addsignup" Click="addsignup_Click" Margin="0,40"/>
        <Button Grid.Column="5" Grid.Row="4" VerticalAlignment="Top" Background="Aquamarine"  Content="Update" FontSize="45" x:Name="upsignup" Click="upsignup_Click"/>
        <TextBlock Grid.Row="3" Grid.Column="3" VerticalAlignment="Top" Text="תאריך רישום" FontSize="30" HorizontalAlignment="Right"/>
        <DatePicker Grid.Row="3" Grid.Column="3" x:Name="SignDate" VerticalAlignment="Bottom" Height="70"/>
        <TextBlock Grid.Row="3" Grid.Column="1" VerticalAlignment="Top" Text="תאריך סיום רישום" FontSize="25" HorizontalAlignment="Right" />
        <DatePicker Grid.Row="3" Grid.Column="1" x:Name="EndSignTime" VerticalAlignment="Bottom" Height="70"/>
        <ListView Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="3" Margin="20" FlowDirection="RightToLeft" x:Name="lstvsignup" SelectionChanged="lstvsignup_SelectionChanged">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="תאריך רישום" Width="200" DisplayMemberBinding="{Binding SignDate}"/>
                    <GridViewColumn Header="תאריך סיום רישום" Width="200" DisplayMemberBinding="{Binding EndSignTime}"/>
                    <GridViewColumn Header="שם" Width="200" DisplayMemberBinding="{Binding IdClient.Fname}"/>
                    <GridViewColumn Header="משפחה" Width="200" DisplayMemberBinding="{Binding IdClient.Lname}"/>
                </GridView>
            </ListView.View>
        </ListView>
        <TextBlock Grid.Row="3" Grid.Column="4" Margin="15" Text="שימו לב בזמן רישום התאריך" VerticalAlignment="Top" Background="Azure" />
        <TextBlock Grid.Row="3" Grid.Column="4" Margin="15" Text="הפרטים האישיים צריכים" VerticalAlignment="Center" Background="Azure" />
        <TextBlock Grid.Row="3" Grid.Column="4" Margin="15" Text="להיות מלאים" VerticalAlignment="Bottom" Background="Azure" />

    </Grid>
</Page>
