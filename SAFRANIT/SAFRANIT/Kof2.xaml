<Page x:Class="SAFRANIT.Kof2"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SAFRANIT"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Kof2" Loaded="Page_Loaded">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>
        <TextBlock   Text="  שם סוג ספר" Grid.Row="0" Grid.Column="2"  Margin="20,0"   FontSize="50" Background="Honeydew" VerticalAlignment="Bottom"/>
        <TextBox    x:Name="NameKindOfBook" Grid.Row="1" Grid.Column="2"  Margin="20" />
        <TextBlock Grid.Row="0" Grid.Column="1" Margin="20,0"  Text=" קוד סוג ספר" FontSize="50" Background="Honeydew" VerticalAlignment="Bottom"/>
        <TextBox Grid.Row="1" Grid.Column="1" Margin="20" x:Name="CodeKindOfBook"/>
        <Button  Margin="20" Grid.Row="0" Grid.Column="0" Background="Honeydew" x:Name="addKindOfBook" Content="add" FontSize="40" Click="addKindOfBook_Click"  />
        <Button  Margin="20" Grid.Row="1" Grid.Column="0" Background="Honeydew" x:Name="newKindOfBook" Content="new" FontSize="40" Click="newKindOfBook_Click"  />
        <ListView x:Name="lstvkindsof" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Grid.RowSpan="2" Height="90" Width="600" >
            <ListView.View>
                <GridView>
                    <GridViewColumn  Header="קוד סוג ספר" Width="300" DisplayMemberBinding="{Binding NameKindOfBook}"/>
                    <GridViewColumn Header="שם סוג ספר" Width="300" DisplayMemberBinding="{Binding CodeKindOfBook}"/>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</Page>
