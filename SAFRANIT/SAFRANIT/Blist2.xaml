<Page x:Class="SAFRANIT.Blist2"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SAFRANIT"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Blist2" Loaded="Page_Loaded">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>
        <ListView x:Name="lstvblist" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="5"  Height="90" Width="750" FlowDirection="RightToLeft" SelectionChanged="lstvblist_SelectionChanged">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="שם ספר" Width="150" DisplayMemberBinding="{Binding NameBook}"/>
                    <GridViewColumn  Header="קוד ספר" Width="150" DisplayMemberBinding="{Binding CodeBook}"/>
                    <GridViewColumn Header="הוצאה לאור" Width="150" DisplayMemberBinding="{Binding CodePublish.NamePublish}"/>
                    <GridViewColumn Header="מספר עותקים" Width="150" DisplayMemberBinding="{Binding Copies}"/>
                    <GridViewColumn Header="סטטוס ספר" Width="150" DisplayMemberBinding="{Binding StatusBook}"/>
                </GridView>
            </ListView.View>
        </ListView>
        <TextBlock   Text="  סטטוס ספר" Grid.Row="0" Grid.Column="1"  Margin="0,20"   FontSize="40" Background="Honeydew" VerticalAlignment="Top" />
        <CheckBox    x:Name="StatusBook" Grid.Row="0" Grid.Column="1"  Margin="20" VerticalAlignment="Bottom" />
        <TextBlock   Text="  הוצאה לאור" Grid.Row="0" Grid.Column="2"  Margin="0,20"   FontSize="40" Background="Honeydew" VerticalAlignment="Top"/>
        <ComboBox    x:Name="CodePublish" Grid.Row="0" Grid.Column="2"  Margin="20" VerticalAlignment="Bottom" FontSize="30"/>
        <TextBlock   Text="  קוד ספר" Grid.Row="0" Grid.Column="3"  Margin="0,20"   FontSize="40" Background="Honeydew" VerticalAlignment="Top"/>
        <TextBox    x:Name="CodeBook" Grid.Row="0" Grid.Column="3"  Margin="20" VerticalAlignment="Bottom" FontSize="30"/>
        <TextBlock   Text=" שם ספר" Grid.Row="0" Grid.Column="4"  Margin="0,20"   FontSize="40" Background="Honeydew" VerticalAlignment="Top"/>
        <TextBox    x:Name="NameBook" Grid.Row="0" Grid.Column="4"  Margin="20" VerticalAlignment="Bottom" FontSize="30"/>
        <Button x:Name="choosepicture" Grid.Row="0" Grid.Column="0" Content="בחר תמונה" Margin="40" FontSize="30" Background="Honeydew" Click="choosepicture_Click"/>
        <Image x:Name="pic" Grid.Column="0" Grid.Row="1" Margin="20"/>
        <Button Grid.Column="3" Grid.Row="1" Content=" Add" Margin="40"  x:Name="addbk"  Background="Honeydew" FontSize="30" Click="addbk_Click"/>
        <Button Grid.Column="4" Grid.Row="1" Content=" New" Margin="40"  x:Name="newbk"  Background="Honeydew" FontSize="30" Click="newbk_Click"/>
        <Button Grid.Column="2" Grid.Row="1" Content=" Update" Margin="40"  x:Name="upbk"  Background="Honeydew" FontSize="30" Click="upbk_Click"/>
        <Button Grid.Column="1" Grid.Row="1" Content=" delete status" Margin="40"  x:Name="destalbk"  Background="Honeydew" FontSize="20" Click="destalbk_Click"/>
    </Grid>
</Page>
