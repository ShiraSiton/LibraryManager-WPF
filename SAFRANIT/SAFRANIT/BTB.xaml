<Page x:Class="SAFRANIT.BTB"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SAFRANIT"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800" Background="White"
      Title="BTB" Loaded="Page_Loaded">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="2*"/>
        </Grid.RowDefinitions>
        <ComboBox Grid.Row="0" Grid.RowSpan="2" Grid.Column="2" Height="150" Width="250" x:Name="CodeBook" FontSize="30"/>
        <TextBlock Grid.Row="0" Grid.Column="1"  Text=" כמות עותקים נוספת" FontSize="50" Background="BlanchedAlmond" Height="70" VerticalAlignment="Bottom"/>
        <TextBox Grid.Row="1" Grid.Column="1"  Height="70"  x:Name="Copies" FontSize="30" TextAlignment="Center"/>
        <ListView x:Name="lstvBTB" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3"  Height="90" Width="600" FlowDirection="RightToLeft">
            <ListView.View>
                <GridView>
                    <GridViewColumn  Header=" ספר" Width="200" DisplayMemberBinding="{Binding CodeBook.NameBook}"/>
                    <GridViewColumn Header=" קוד סידורי" Width="200" DisplayMemberBinding="{Binding CodeSidoory}"/>
                    <GridViewColumn  Header=" סטטוס ספר" Width="200" DisplayMemberBinding="{Binding StatusToBorrow}"/>
                </GridView>
            </ListView.View>
        </ListView>
        <Button x:Name="b1" Grid.Row="0" Grid.RowSpan="2" Grid.Column="0" Height="150" Width="250" Content="אישור" FontSize="40" Background="BlanchedAlmond" Click="b1_Click"/>
    </Grid>
</Page>
